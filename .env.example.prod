# Production Environment Variables for docker-compose.prod.yml
# Copy this file to .env.prod and fill in the actual values

# PostgreSQL Configuration
POSTGRES_USER=sms_user
POSTGRES_PASSWORD=your_secure_postgres_password_here

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password_here

# JWT Secret (use a strong, random value)
JWT_SECRET=your_strong_jwt_secret_key_here

# Docker Image References (from GitHub Container Registry)
BACKEND_IMAGE=ghcr.io/yourusername/sms/backend:latest
FRONTEND_IMAGE=ghcr.io/yourusername/sms/frontend:latest

# Node Environment
NODE_ENV=production
